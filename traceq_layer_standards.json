  "ignore_layers": {
    "description": "Layers that should never be classified as equipment",
    "patterns": ["TEXT", "DIM", "ANNOTATION", "ARROW", "XREF", "DEFPOINTS", "BORDER",
                 "GRID", "AXIS", "FRAME", "LEGEND", "TITLE", "NOTES", "LEADER",
                 "HATCH", "SECTION", "DETAIL", "SCHEDULE", "SCHEMATIC"]
  },

  "tier1_skip_blocks": {
    "_description": "Block names to EXCLUDE from Tier 1 (layer-based) counting. These are universally non-equipment blocks that appear on equipment layers (e.g., airflow arrows on grille layers). Case-insensitive matching.",
    "_rationale": "Tier 1 counts ALL INSERT entities on a classified layer. But many INSERTs on equipment layers are annotation/accessory blocks (arrows showing airflow direction, wire mesh symbols, legend items) — not actual equipment. This filter prevents overcounting.",
    "exact_names": [
      "legend",
      "_ArchTick",
      "FIN"
    ],
    "contains_substrings": [
      "ARROW",
      "WIRE MESH"
    ]
  }
}
