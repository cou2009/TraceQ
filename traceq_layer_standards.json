{
  "_version": "1.3",
  "_source": "Nestor NHM layer standards + HVAC layer standards + Nestor feedback March 20 (25 new abbreviations)",
  "_notes": "Fuzzy matching uses keywords array. Exact match checked first, then keyword tokens. IMPORTANT: 2-letter keywords removed in v1.2 — they caused false layer classifications.",
  "_changelog": "v1.3 (Mar 23): Added tier1_skip_blocks to filter known non-equipment blocks from layer-based counting. v1.2 (Mar 20): Removed all problematic 2-letter keywords (SD, RD, ED, VD, MD, TH, EF, SF, RF, BF, SA, EA, RA) that caused layer misclassification regression. Kept 3+ letter Nestor abbreviations (SLSD, RLSD, MSD, OBD, PBD, etc.).",

  "equipment_categories": {
    "supply_diffuser": {
      "description": "Supply air diffusers (ceiling/wall mounted)",
